# Helm — Plaid connector config.
# Copy this file to `.env` and fill in your keys. Plaid Sandbox is FREE, instant, and
# uses no real money. Without keys, the connector runs in DEMO mode (realistic sandbox
# holdings) so the flow still works — it flips to real the moment you add keys here.
#
# Get keys: https://dashboard.plaid.com/signup → Team Settings → Keys (use the Sandbox).

PLAID_CLIENT_ID=
PLAID_SECRET=

# sandbox | development | production
PLAID_ENV=sandbox

# TallyPrime (India) — local HTTP-XML gateway URL (in Tally: F1 → enable XML/HTTP on a port,
# usually 9000). Leave blank to run Tally in DEMO mode (a realistic INR pharmacy series).
TALLY_URL=

# Port for the STANDALONE connector (`npm run server`). Not needed for `npm run dev`,
# which mounts the connector inside Vite automatically.
PORT=8787

# ── Claude brain (the "AI COO") ────────────────────────────────────────────────
# The server brokers Anthropic's Claude so the key NEVER reaches the browser. With a key,
# /api/agent/status flips to available:true and Ask Helm / the Morning Brief / Action drafts
# light up. WITHOUT a key, every agent route returns { available:false } and the app falls
# back to the offline rule engine — it never breaks. Get a key + set a SPEND CAP at
# https://console.anthropic.com (the /api/agent relay is unauthenticated, billed to this key).
ANTHROPIC_API_KEY=

# Model overrides (optional). Sonnet 4.6 for the interactive, low-latency paths (Ask + drafts);
# Opus 4.8 for the once-daily Brief (extended thinking). Leave blank to use these defaults.
HELM_ASK_MODEL=claude-sonnet-4-6
HELM_BRIEF_MODEL=claude-opus-4-8

# ── Brief cost gate ("loop engineering": cheap checker decides, expensive maker writes) ────────
# The morning Brief is the priciest call in Helm. Instead of firing Opus on every app open, a free
# σ-anomaly rule check runs first, then a cheap Haiku "checker" decides if anything materially
# changed — and ONLY then does the Opus "maker" write a new brief. The client also caches the brief
# by a data fingerprint, so reopening the app on unchanged data costs nothing.
#   HELM_BRIEF_MODE:  off (no AI brief) | rules (fire Opus on any σ-anomaly/alert) | haiku-gated (default) | always
#   HELM_CHECK_MODEL: the cheap model for the material-change checker (Haiku).
#   HELM_BRIEF_DAILY_CAP: hard backstop — max Opus briefs/day (the client enforces this durably too).
HELM_BRIEF_MODE=haiku-gated
HELM_CHECK_MODEL=claude-haiku-4-5
HELM_BRIEF_DAILY_CAP=1

# ── Public-relay abuse guard (set these on any PUBLIC deploy with a key) ────────────────────────
# The /api/agent/* routes are unauthenticated and billed to ANTHROPIC_API_KEY, so an open relay
# lets anyone who finds the URL spend the budget. These gate the billed routes (Ask/Brief/Draft/
# Vision); /status stays open. Best-effort, infra-free — the hard ceiling is still the credit
# balance, so KEEP VERCEL AUTO-RELOAD OFF.
#   HELM_ALLOWED_ORIGINS: comma-separated host allowlist (no scheme), e.g.
#     "helm-ten-delta.vercel.app,helmhq.app". Empty = not enforced (dev). THE primary lever — set
#     this in Vercel; no frontend rebuild needed.
#   HELM_CLIENT_SECRET: optional shared secret the server requires via the x-helm-key header. Set it
#     TOGETHER with the frontend's VITE_HELM_CLIENT_SECRET (build-time) or the AI degrades to rules.
#   HELM_AGENT_IP_CAP / HELM_AGENT_IP_WINDOW_MIN: per-IP rate limit (default 40 calls / 10 min).
#   HELM_AGENT_DAILY_CAP: global daily call backstop across all billed routes (default 300).
HELM_ALLOWED_ORIGINS=
HELM_CLIENT_SECRET=
# VITE_HELM_CLIENT_SECRET must equal HELM_CLIENT_SECRET (it's read at build time by the frontend).
VITE_HELM_CLIENT_SECRET=
HELM_AGENT_IP_CAP=40
HELM_AGENT_IP_WINDOW_MIN=10
HELM_AGENT_DAILY_CAP=300
